    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.99.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.2",
    "vite": "^8.0.9"
  }
