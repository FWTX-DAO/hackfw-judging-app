{
  "name": "hackfw-judging-app",
  "module": "src/server/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun --hot src/server/index.ts",
