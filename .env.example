# ─── Required in production ────────────────────────────────────────────
# Long random string — signs judge/admin session tokens. Rotating it
# invalidates every existing session. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Admin console PIN. Treat like a password — long and random.
ADMIN_PIN=

# ─── Common ────────────────────────────────────────────────────────────
# HTTP listen port (default 3000)
PORT=3000

# Where SQLite + WAL files live. In Docker / Fly, point this at your
# mounted volume (e.g. /data/hackathon.db).
DB_FILE=data/hackathon.db

# Set to "production" to enable strict mode: refuse to boot without
# SESSION_SECRET + ADMIN_PIN, and don't echo the PIN in logs.
NODE_ENV=development

# ─── Optional: Turso embedded-replica sync ─────────────────────────────
# Leave unset for local-only operation. With these set, the local DB
# becomes a libSQL embedded replica that syncs with a remote Turso DB.
# TURSO_SYNC_URL=
# TURSO_AUTH_TOKEN=
# TURSO_SYNC_INTERVAL=60       # seconds — libSQL pull cadence
# TURSO_SYNC_TICK_MS=30000     # ms — server-side sync tick
